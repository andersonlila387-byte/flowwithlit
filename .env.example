# Database (Hostinger MySQL remote host, or free DB on Railway/Render)
DB_USER=your_db_user
DB_PASS=your_db_password
DB_HOST=your_db_host
DB_PORT=3306
DB_NAME=flowwithlit_db

# Auth — generate a long random string for production
JWT_SECRET=change-me-to-a-long-random-secret

# Email via PHP on Hostinger (Go calls this URL)
MAIL_DISPATCH_URL=https://flowwithlit.com/mail/dispatch.php
MAIL_DISPATCH_SECRET=change-me-mail-dispatch-secret

# Optional SMTP (Go can also send; PHP mailer uses mail.config on Hostinger)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@flowwithlit.com

# Optional — support chatbot
ANTHROPIC_API_KEY=

# Server port (Render/Fly set PORT automatically; local default 8081)
PORT=8081