# Database (Hostinger remote host from hPanel → Databases → Remote MySQL)
DB_USER=your_db_user
DB_PASS=your_db_password
DB_HOST=your_db_host
DB_PORT=3306
DB_NAME=flowwithlit_db

# Auth — generate a long random string for production
JWT_SECRET=change-me-to-a-long-random-secret

# App environment — set production on Render; local dev omits this or uses development
ENVIRONMENT=production

# Email: Go API always sends mail via PHP on Hostinger (not Go SMTP).
# Local dev:
#   MAIL_DISPATCH_URL=http://localhost/flowwithlit/mail/dispatch.php
# Production (Render) — either set explicitly OR rely on ENVIRONMENT=production default:
MAIL_DISPATCH_URL=https://flowwithlit.com/mail/dispatch.php
MAIL_DISPATCH_SECRET=change-me-mail-dispatch-secret

# SMTP lives in PHP mail.config.local.php on Hostinger (noreply@flowwithlit.com).
# These are only used if EMAIL_ALLOW_GOMAIL_FALLBACK=true (leave unset in production).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@flowwithlit.com
SMTP_PASS=
SMTP_FROM=noreply@flowwithlit.com

# Support chatbot (Aria) — switch providers with AI_PROVIDER alone, no code changes.
# Values: gemini (default) | grok | huggingface. Only the matching *_API_KEY below
# is required for whichever provider you pick.
AI_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

GROK_API_KEY=
GROK_MODEL=grok-4

HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Server port (Render/Fly set PORT automatically; local default 8081)
PORT=8081